# ─────────────────────────────────────────────
# OmniFlow Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# API
API_VERSION=v1

# Database (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/omniflow_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"


# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# JWT Authentication
JWT_SECRET=your_jwt_secret_minimum_32_characters

# Pinecone Vector Store
PINECONE_API_KEY=your_pinecone_api_key

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_meta_developer_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verification_token

