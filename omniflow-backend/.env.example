# ─────────────────────────────────────────────
# OmniFlow Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# API
API_VERSION=v1

# Database (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/omniflow_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"


# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
